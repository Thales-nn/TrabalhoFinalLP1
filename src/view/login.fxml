<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0"
            prefWidth="500.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.LoginController">

    <children>

        <Label layoutX="180"
               layoutY="40"
               text="Login" />

        <TextField fx:id="txtUsuario"
                   layoutX="150"
                   layoutY="120"
                   prefWidth="200"
                   promptText="Usuário" />

        <PasswordField fx:id="txtSenha"
                       layoutX="150"
                       layoutY="180"
                       prefWidth="200"
                       promptText="Senha" />

        <Button layoutX="150"
                layoutY="250"
                prefWidth="90"
                text="Entrar"
                onAction="#entrar" />

        <Button layoutX="260"
                layoutY="250"
                prefWidth="90"
                text="Registrar"
                onAction="#abrirCadastro" />

    </children>

</AnchorPane>