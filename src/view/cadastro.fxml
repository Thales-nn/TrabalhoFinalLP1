<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane stylesheets="@style.css"
            prefHeight="300.0"
            prefWidth="400.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.CadastroController">

    <children>

        <Label layoutX="150"
               layoutY="50"
               text="Cadastro"
               styleClass="titulo" />

        <TextField fx:id="txtNovoUsuario"
                   layoutX="100"
                   layoutY="90"
                   prefWidth="200"
                   promptText="Usuário" />

        <PasswordField fx:id="txtNovaSenha"
                       layoutX="100"
                       layoutY="140"
                       prefWidth="200"
                       promptText="Senha" />

        <Button layoutX="100"
                layoutY="200"
                prefWidth="200"
                text="Cadastrar"
                onAction="#cadastrar"
                styleClass="cadastro" />

    </children>

</AnchorPane>